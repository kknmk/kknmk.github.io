@article{chenImpactPopulationAging2024,
  title = {Impact of Population Aging on Future Temperature-Related Mortality at Different Global Warming Levels},
  author = {Chen, Kai and family=Schrijver, given=Evan, prefix=de, useprefix=true and Sivaraj, Sidharth and Sera, Francesco and Scovronick, Noah and Jiang, Leiwen and Roye, Dominic and Lavigne, Eric and Kyselý, Jan and Urban, Aleš and Schneider, Alexandra and Huber, Veronika and Madureira, Joana and Mistry, Malcolm N. and Cvijanovic, Ivana and Armstrong, Ben and Schneider, Rochelle and Tobias, Aurelio and Astrom, Christofer and Guo, Yuming and Honda, Yasushi and Abrutzky, Rosana and Tong, Shilu and family=Sousa Zanotti Stagliorio Coelho, given=Micheline, prefix=de, useprefix=true and Saldiva, Paulo Hilario Nascimento and Correa, Patricia Matus and Ortega, Nicolás Valdés and Kan, Haidong and Osorio, Samuel and Orru, Hans and Indermitte, Ene and Jaakkola, Jouni J. K. and Ryti, Niilo and Pascal, Mathilde and Katsouyanni, Klea and Analitis, Antonis and Mayvaneh, Fatemeh and Entezari, Alireza and Goodman, Patrick and Zeka, Ariana and Michelozzi, Paola and family=Donato, given=Francesca, prefix=de’, useprefix=true and Hashizume, Masahiro and Alahmad, Barrak and Diaz, Magali Hurtado and De la Cruz Valencia, César and Overcenco, Ala and Houthuijs, Danny and Ameling, Caroline and Rao, Shilpa and Carrasco-Escobar, Gabriel and Seposo, Xerxes and family=Silva, given=Susana Pereira, prefix=da, useprefix=true and Holobaca, Iulian Horia and Acquaotta, Fiorella and Kim, Ho and Lee, Whanhee and Íñiguez, Carmen and Forsberg, Bertil and Ragettli, Martina S. and Guo, Yue-Liang Leon and Pan, Shih-Chun and Li, Shanshan and Colistro, Valentina and Zanobetti, Antonella and Schwartz, Joel and Dang, Tran Ngoc and Van Dung, Do and Carlsen, Hanne Krage and Cauchi, John Paul and Achilleos, Souzana and Raz, Raanan and Gasparrini, Antonio and Vicedo-Cabrera, Ana M. and {MCC Collaborative Research Network}},
  date = {2024-02-27},
  journaltitle = {Nature Communications},
  shortjournal = {Nature Communications},
  volume = {15},
  number = {1},
  pages = {1796},
  issn = {2041-1723},
  doi = {10.1038/s41467-024-45901-z},
  url = {https://doi.org/10.1038/s41467-024-45901-z},
  abstract = {Older adults are generally amongst the most vulnerable to heat and cold. While temperature-related health impacts are projected to increase with global warming, the influence of population aging on these trends remains unclear. Here we show that at 1.5\,°C, 2\,°C, and 3\,°C of global warming, heat-related mortality in 800 locations across 50 countries/areas will increase by 0.5\%, 1.0\%, and 2.5\%, respectively; among which 1 in 5 to 1 in 4 heat-related deaths can be attributed to population aging. Despite a projected decrease in cold-related mortality due to progressive warming alone, population aging will mostly counteract this trend, leading to a net increase in cold-related mortality by 0.1\%–0.4\% at 1.5–3\,°C global warming. Our findings indicate that population aging constitutes a crucial driver for future heat- and cold-related deaths, with increasing mortality burden for both heat and cold due to the aging population.}
}

