@article{ohlertDroughtIntensityDuration2025,
  title = {Drought Intensity and Duration Interact to Magnify Losses in Primary Productivity},
  author = {Ohlert, Timothy and Smith, Melinda D. and Collins, Scott L. and Knapp, Alan K. and Dukes, Jeffrey S. and Sala, Osvaldo and Wilkins, Kate D. and Munson, Seth M. and Anderson, Maggie I. and Avolio, Meghan L. and Chen, Anping and Hayden, Meghan T. and Holdrege, Martin C. and Slette, Ingrid J. and Wilfahrt, Peter and Beier, Claus and Fraser, Lauchlan H. and Jentsch, Anke and Loik, Michael E. and Luo, Yiqi and Maestre, Fernando T. and Phillips, Richard P. and Power, Sally A. and Yahdjian, Laura and Yu, Qiang and Chen, Angel and Felton, Andrew J. and Gherardi, Laureano A. and Lyon, Nicholas J. and Abdoli, Hamed and Abedi, Mehdi and Alberti, Juan and Arroyo, Antonio I. and Asbjornsen, Heidi and Auge, Harald and Bachle, Seton and Bahn, Michael and Bartholomew, David C. and Batbaatar, Amgaa and Bauerle, Taryn L. and Beard, Karen H. and Behn, Kai and Beil, Ilka and Biancari, Lucio and Blindow, Irmgard and Bondaruk, Viviana Florencia and Borer, Elizabeth T. and Bork, Edward W. and Bruschetti, Carlos Martin and Byrne, Kerry M. and Cahill, James F. and Calvo, Dianela A. and Carbognani, Michele and Carlyle, Cameron N. and Castillioni, Karen and Castillo-Garcia, Miguel and Chandregowda, Manjunatha H. and Chang, Scott X. and Chieppa, Jeff and Churchill, Amber C. and Cianciaruso, Marcus Vinicius and Cordeiro, Amanda L and Cousins, Sara A. O. and Cusack, Daniela F. and Dahlke, Sven and Daleo, Pedro and Dietterich, Lee H. and Dubbert, Maren and Eisenhauer, Nico and Forte, T’ai G. W. and Funk, Flavia A. and Galiano, Darcy and Greenville, Aaron C. and Han, Liebao and Haugum, Siri Vatsø and Hautier, Yann and Hector, Andy and Henry, Hugh A. L. and Hoss, Daniela and Isbell, Forest and Jordan, Samuel E. and Ke, Yuguang and Kelly, Eugene F. and Koerner, Sally E. and Kreyling, Juergen and Kröel-Dulay, György and Kröpfl, Alicia I. and Kübert, Angelika and Kulmatiski, Andrew and Lamb, Eric G. and Larsen, Klaus Steenberg and Lee, Steven and Limbu, Smriti Pehim and Linstädter, Anja and Liu, Shirong and Longo, Grisel and Loydi, Alejandro and Luan, Junwei and Lubbe, F. Curtis and Malyshev, Andrey V. and McIntire, Cameron D. and Metcalfe, Daniel B. and Mokoka, Malesela Vincent and Mori, Akira S. and Mudongo, Edwin and Newman, Gregory S. and Nielsen, Uffe N. and Ochoa-Hueso, Raúl and O’Connor, Rory C. and Ogaya, Romà and Oñatibia, Gastón R. and Orbán, Ildikó and Osborne, Brooke B. and Otfinowski, Rafael and Pärtel, Meelis and Pascual, Jesús and Peñuelas, Josep and Peri, Pablo L. and Pescador, David S. and Peter, Guadalupe and Petraglia, Alessandro and Picon-Cochard, Catherine and Pillar, Valério D. and Piñeiro-Guerra, Juan M. and Ploughe, Laura Weber and Plowes, Robert M. and Portales-Reyes, Cristy and Prober, Suzanne M. and Pueyo, Yolanda and Rahmati, Golsa and Reed, Sasha C. and Rodríguez, Dana Aylén and Rogers, William E. and Roscher, Christiane and Rowley, David W. and Sánchez, Ana M. and Santos, Bráulio A. and Schellenberg, Michael P. and Scherer-Lorenzen, Michael and Seabloom, Eric W. and Shen, Ruonan and Shi, Baoku and Souza, Lara and Stampfli, Andreas and Standish, Rachel J. and Sternberg, Marcelo and Sun, Wei and Sünnemann, Marie and Tedder, Michelle and Terry, Tyson J. and Thorvaldsen, Pål and Tielbörger, Katja and Tissink, Maud and Vadeboncoeur, Matthew A. and Valdecantos, Alejandro and family=Brink, given=Liesbeth, prefix=van den, useprefix=true and Vandvik, Vigdis and Velle, Liv Guri and Wanke, Svenja and Wardle, Glenda M. and Wei, Cunzheng and Werner, Christiane and Wiehl, Georg and Williams, Jennifer L. and Wolf, Amelia A. and Wu, Honghui and Xu, Chong and Yang, Xuechen and Yang, Yadong and Yost, Jenifer L. and Young, Alyssa L. and Yue, Ping and Zeberio, Juan M. and Zeiter, Michaela and Zhang, Haiyang and Zhu, Juntao and Zuo, Xiaoan},
  date = {2025-10-16},
  journaltitle = {Science},
  shortjournal = {Science},
  volume = {390},
  number = {6770},
  pages = {284--289},
  publisher = {American Association for the Advancement of Science},
  doi = {10.1126/science.ads8144},
  url = {https://doi.org/10.1126/science.ads8144},
  urldate = {2025-10-22},
  abstract = {As droughts become longer and more intense, impacts on terrestrial primary productivity are expected to increase progressively. Yet, some ecosystems appear to acclimate to multiyear drought, with constant or diminishing reductions in productivity as drought duration increases. We quantified the combined effects of drought duration and intensity on aboveground productivity in 74 grasslands and shrublands distributed globally. Ecosystem acclimation with multiyear drought was observed overall, except when droughts were extreme (i.e., ≤1-in-100-year likelihood of occurrence). Productivity losses after four consecutive years of extreme drought increased by \textasciitilde 2.5-fold compared with those of the first year. These results portend a foundational shift in ecosystem behavior if drought duration and intensity increase, from maintenance of reduced functioning over time to progressive and profound losses of productivity when droughts are extreme. Climate change is bringing more severe and longer-lasting droughts to many locations around the world. Some ecosystems have shown resilience to increasing drought, but this could change as droughts become more severe. Ohlert et al. assessed drought effects with a rainfall-exclusion experiment distributed across 74 grasslands and shrublands on six continents. On average, primary productivity declined by 29\% in moderate-drought years, but effects did not compound over multiyear droughts. Extreme droughts (those falling outside the historic range of rainfall variability) caused much higher productivity declines and lower recovery, especially in drier locations and those with lower plant diversity. This study adds to growing evidence that future climate extremes will likely affect ecosystems in new and concerning ways. ?Bianca Lopez}
}

