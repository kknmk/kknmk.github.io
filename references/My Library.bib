@article{benvenisteGlobalClimateMigration2025,
  title = {Global Climate Migration Is a Story of Who and Not Just How Many},
  author = {Benveniste, Hélène and Huybers, Peter and Proctor, Jonathan},
  date = {2025-09-03},
  journaltitle = {Nature Communications},
  shortjournal = {Nature Communications},
  volume = {16},
  number = {1},
  pages = {7752},
  issn = {2041-1723},
  doi = {10.1038/s41467-025-62969-3},
  url = {https://doi.org/10.1038/s41467-025-62969-3},
  abstract = {Understanding the impact of climate change on human migration is critical for policymakers. Yet climate change can both incentivize people to migrate and reduce their ability to move, making its effect on human migration ambiguous. We propose an approach to studying migration that combines causal inference methods with cross-validation techniques to reliably estimate effects of weather on migration within and across borders. This approach highlights the key role of migrant demographics in the weather-migration relationship. We show that allowing weather effects to differ by age and education improves out-of-sample performance by a factor of five or more compared with a homogeneous effect. Demographic heterogeneity is critical in explaining this discrepancy. Projections based on our empirical estimates indicate that the effects of climate change on future cross-border migration will be an order of magnitude larger for most demographics than the average effect, but differing responses across groups largely offset one another.}
}

