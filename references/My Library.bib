@article{10.1093/ije/dyaf120,
  title = {Spatial {{Bayesian}} Distributed Lag Non-Linear Models with {{R-INLA}}},
  author = {Quijal-Zamorano, Marcos and Martinez-Beneito, Miguel A and Ballester, Joan and Marí-Dell’Olmo, Marc},
  date = {2025-07},
  journaltitle = {International Journal of Epidemiology},
  volume = {54},
  number = {4},
  eprint = {https://academic.oup.com/ije/article-pdf/54/4/dyaf120/63824184/dyaf120.pdf},
  pages = {dyaf120},
  issn = {1464-3685},
  doi = {10.1093/ije/dyaf120},
  url = {https://doi.org/10.1093/ije/dyaf120},
  abstract = {In a recent paper published in this Journal,1 we introduced spatial Bayesian distributed lag non-linear models (SB-DLNMs) as a novel framework for estimating the short-term lagged health effects of environmental exposures in small areas. We extended the state-of-the-art approach for exposure–lag–response epidemiological modelling—distributed lag non-linear models (DLNMs)2—by incorporating spatial models within a single-stage Bayesian framework to account for spatial dependence in risks. To evidence the practicality of SB-DLNMs, we conducted a case study estimating the temperature–lag–mortality relationships in the 73 neighbourhoods of Barcelona. SB-DLNMs can be implemented by using various Bayesian statistical software tools. We used WinBUGS for its flexibility in specifying complex hierarchical Bayesian models.3 However, besides the need for conducting simulation studies that validate the robustness of the models, we acknowledged in the original paper that the biggest limitation of SB-DLNMs is their long execution times and high computational demands. As an alternative, R-INLA, based on integrated nested Laplace approximations,4 offers faster computation compared with software alternatives using Markov chain Monte Carlo (MCMC),5 such as WinBUGS. In this letter, we present the implementation of SB-DLNMs with R-INLA providing the illustrative code to reproduce the results of the same case study of small-area temperature–mortality associations in the Supplementary Text S1 and in a GitHub repository (https://github.com/marcosqz/sbdlnm\_rinla\_implementation).}
}

